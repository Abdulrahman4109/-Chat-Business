{
  "name": "ChatRecord",
  "nodeType": "REGULAR",
  "description": "Financial chat conversation record stored in Mujarrad space",
  "fields": {
    "id": { "type": "string", "description": "Unique record identifier (UUID)" },
    "user_id": { "type": "string", "description": "User identifier" },
    "conversation_id": { "type": "string", "description": "Conversation group identifier" },
    "user_message": {
      "type": "object",
      "description": "User's chat message",
      "fields": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user"] },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "datetime" }
      }
    },
    "assistant_message": {
      "type": "object",
      "description": "Assistant's response with extracted data and calculation",
      "fields": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["assistant"] },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "datetime" },
        "extracted_data": { "$ref": "#/definitions/FinancialData" },
        "calculation": { "$ref": "#/definitions/CalculationResult" }
      }
    },
    "extracted_data": { "$ref": "#/definitions/FinancialData" },
    "calculation": { "$ref": "#/definitions/CalculationResult" },
    "created_at": { "type": "string", "format": "datetime" }
  },
  "definitions": {
    "FinancialData": {
      "type": "object",
      "fields": {
        "goal_price": { "type": "number", "nullable": true },
        "monthly_income": { "type": "number", "nullable": true },
        "monthly_expenses": { "type": "number" },
        "current_savings": { "type": "number" },
        "extra_income": { "type": "number" },
        "goals": { "type": "array", "items": { "type": "object" } },
        "all_numbers": { "type": "array", "items": { "type": "number" } },
        "assumptions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "CalculationResult": {
      "type": "object",
      "fields": {
        "net_monthly_savings": { "type": "number" },
        "remaining": { "type": "number" },
        "months": { "type": "number", "nullable": true },
        "raw_months": { "type": "number", "nullable": true },
        "duration_display": { "type": "string" },
        "is_achievable": { "type": "boolean" },
        "suggestions": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}